:false,\"group_name\":\"Live-only update\",\"is_experiment_active\":true,\"is_user_in_experiment\":true},\"4223845460\":{\"name\":\"4223845460\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"web_timing_max_attempts\":10,\"timing_cancel_send_timeout_sec\":10,\"timing_unsend_window_sec\":7,\"web_timing_poll_interval_ms\":1500,\"timing_unsend_buffer_sec\":3},\"is_device_based\":false,\"passed\":false},\"1977158438\":{\"name\":\"1977158438\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"enable_web_search\":false,\"user_prompt_key\":\"good_option\",\"system_prompt\":\"The user is asking about an ad shown to them by {advertiser}. Your response must be about the ad shown. They are using the \\\"Ask ChatGPT\\\" feature to get ChatGPT's honest opinion on the product(s) in the advertisement, and in which situations it could be a great fit for them. You should be honest about when you think the product(s) would vs. would not be useful for the user, based on what you know about them.\\n\\nInformation about the ad:\\n{ad}.\\n\\nStructure your response in the following manner:\\n- Briefly describe the type of user, use case, or situation where this ad/product makes sense for the user.\\n- If appropriate, explain any mismatches with the user's stated preferences or goals. That is, where might it fall short for the user (if appropriate)? You don't have to do this for every query, but feel free to list limitations if you think they're pretty relevant.\\n- Give a concise recommendation (e.g., \\\"worth considering,\\\" \\\"probably not ideal,\\\" \\\"good budget option,\\\" \\\"seriously may be a fit,\\\" etc.)\\n\\nGuidelines:\\n- Be honest and practical.\\n- Do not blindly promote the ad.\\n- Avoid harsh or absolute negative language.\\n- Do not invent details not present in the ad.\\n- Focus on fit, not feature lists.\\n- If the mark on relevance is clearly missed, feel free to be funny with it and keep it lighthearted. Do not mock the user or advertiser; keep the humor gentle.\\n\\nKeep it concise, direct, and easy to scan.\\n\\n{conversation}\"},\"is_device_based\":false,\"passed\":false},\"574611634\":{\"name\":\"574611634\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"connector_link_policies\":{\"connector_2128aebfecb84f64a069897515042a44\":{\"link_created_at_min\":\"2026-03-03T22:00:00Z\"}}},\"is_device_based\":false,\"passed\":false},\"247832287\":{\"name\":\"247832287\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"payment_method_order\":[]},\"is_device_based\":false,\"passed\":false},\"2921297473\":{\"name\":\"2921297473\",\"rule_id\":\"launchedGroup\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"enabled\":true},\"is_device_based\":false,\"group_name\":\"Test\",\"is_experiment_active\":false,\"is_user_in_experiment\":false},\"944963740\":{\"name\":\"944963740\",\"rule_id\":\"prestart\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{},\"is_device_based\":false,\"is_experiment_active\":false,\"is_user_in_experiment\":false},\"550560761\":{\"name\":\"550560761\",\"rule_id\":\"default\",\"secondary_exposures\":[],\"id_type\":\"userID\",\"value\":{\"history_results_limit\":6,\"local_results_limit\":2},\"is_device_based\":false,\"passed\":false},\"3553340571\":{\"name\":\"3553340571\",\"rule_id\":\"63IPFlpcl4A1IhlxgO9O7U:100.00:2-63IPFjK9SMqxoRNBFGeaOS\",\"secondary_exposures\":[{\"gate\":\"3667271925\",\"gateValue\":\"false\",\"ruleID\":\"default\"},{\"gate\":\"3965332612\",\"gateValue\":\"false\",\"ruleID\":\"default\"},{\"gate\":\"1662690995\",\"gateValue\":\"false\",\"ruleID\":\"default\"}],\"id_type\":\"workspace_id\",\"value\":{\"enable_pineapple\":true,\"enable_separate_pineapple\":true,\"enabled_system_skills\":[\"skill-creator\"]},\"is_device_based\":false,\"passed\":true},\"1097139969\":{\"name\":\"1097139969\",\"rule_id\":\"layerAssign